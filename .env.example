# ---------- Banco de dados ----------
POSTGRES_USER=tiescolar
POSTGRES_PASSWORD=tiescolar
POSTGRES_DB=tiescolar
# DSN usado pelo backend (host "db" é o serviço do docker-compose)
DATABASE_URL=postgresql+psycopg://tiescolar:tiescolar@db:5432/tiescolar

# ---------- LLM ----------
# Provedor de geração: "fake" (sem chave, para demo) | "anthropic" | "openai"
LLM_PROVIDER=fake
LLM_MODEL=claude-opus-4-8
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Provedor de embeddings: "fake" (determinístico, sem chave) | "openai"
EMBEDDING_PROVIDER=fake
EMBEDDING_DIM=1536

# ---------- Administração (criados no seed) ----------
# Super admin da plataforma (seu controle, cross-tenant)
SUPER_ADMIN_EMAIL=admin@tiescolar.test
SUPER_ADMIN_SENHA=troque-esta-senha
SUPER_ADMIN_NOME=Super Admin
# Admin do tenant de demonstração (Escola Demonstração)
DEMO_ADMIN_EMAIL=admin@escola-demo.test
DEMO_ADMIN_SENHA=escola123

# ---------- Autenticação (JWT) ----------
# Segredo de assinatura HS256 do token do painel — TROQUE por um valor forte em produção.
JWT_SECRET=troque-este-segredo-jwt
# Validade do token em minutos (480 = 8 horas)
JWT_EXPIRA_MINUTOS=480

# ---------- Canal de mensagens ----------
# Canal padrão de saída: "demo" (in-memory/WS) | "meta"
MESSAGE_CHANNEL=demo

# ---------- Meta WhatsApp Cloud API (outbound) ----------
META_PHONE_NUMBER_ID=
META_WABA_ID=
META_ACCESS_TOKEN=
META_WEBHOOK_VERIFY_TOKEN=changeme
# Limite diário de destinatários únicos por número (tier Meta): 1000 | 10000 | 100000 | -1 (ilimitado)
META_DAILY_TIER_LIMIT=1000

# ---------- App ----------
APP_ENV=development
BACKEND_CORS_ORIGINS=http://localhost:3000
