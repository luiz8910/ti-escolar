# ---------- Banco de dados ----------
POSTGRES_USER=tiescolar
POSTGRES_PASSWORD=tiescolar
POSTGRES_DB=tiescolar
# DSN usado pelo backend (host "db" é o serviço do docker-compose)
DATABASE_URL=postgresql+psycopg://tiescolar:tiescolar@db:5432/tiescolar

# ---------- LLM ----------
# Provedor de geração: "fake" (sem chave, para demo) | "anthropic" | "openai"
LLM_PROVIDER=fake
LLM_MODEL=claude-opus-4-8
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Provedor de embeddings: "fake" (determinístico, sem chave) | "openai"
EMBEDDING_PROVIDER=fake
EMBEDDING_DIM=1536

# ---------- Administração (criados no seed) ----------
# Super admin da plataforma (seu controle, cross-tenant)
SUPER_ADMIN_EMAIL=admin@tiescolar.test
SUPER_ADMIN_SENHA=troque-esta-senha
SUPER_ADMIN_NOME=Super Admin
# Admin do tenant de demonstração (Escola Demonstração)
DEMO_ADMIN_EMAIL=admin@escola-demo.test
DEMO_ADMIN_SENHA=escola123
# Senha do professor demo (login do mural do professor — §A1)
DEMO_PROFESSOR_SENHA=prof123

# ---------- Autenticação (JWT) ----------
# Segredo de assinatura HS256 do token do painel — TROQUE por um valor forte em produção.
JWT_SECRET=troque-este-segredo-jwt
# Validade do token em minutos (480 = 8 horas)
JWT_EXPIRA_MINUTOS=480

# ---------- Canal de mensagens ----------
# Canal padrão de saída: "demo" (in-memory/WS) | "meta" | "twilio"
MESSAGE_CHANNEL=demo

# ---------- Meta WhatsApp Cloud API (outbound) ----------
META_PHONE_NUMBER_ID=
META_WABA_ID=
META_ACCESS_TOKEN=
META_WEBHOOK_VERIFY_TOKEN=changeme
# Limite diário de destinatários únicos por número (tier Meta): 1000 | 10000 | 100000 | -1 (ilimitado)
META_DAILY_TIER_LIMIT=1000

# ---------- Twilio WhatsApp (inbound + outbound) ----------
# Alternativa à Meta; o Sandbox de WhatsApp funciona sem verificação de empresa.
# Credenciais no console do Twilio (Account SID / Auth Token).
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Número remetente PADRÃO do WhatsApp (Sandbox padrão): whatsapp:+14155238886
# Cada escola pode ter o seu próprio número (Tenant.whatsapp_numero); este é o fallback
# usado quando a escola não tem número cadastrado (ex.: número único do Sandbox).
TWILIO_WHATSAPP_FROM=
# URL pública (opcional) para callbacks de status de entrega: https://SEU_DOMINIO/api/webhook/twilio
TWILIO_STATUS_CALLBACK_URL=
# Tenant de fallback do inbound quando o número de destino (To) não casa com nenhuma
# escola cadastrada (ex.: número único do Sandbox). Vazio = tenant demo.
TWILIO_DEFAULT_TENANT_ID=
# Valida X-Twilio-Signature nos webhooks (recomendado em produção): true | false
TWILIO_VALIDATE_SIGNATURE=false

# ---------- Licenciamento / avisos por e-mail ----------
# Janela (em dias) para avisar que a licença anual está perto de vencer.
LICENSE_WARNING_DAYS=30
# Remetente dos e-mails administrativos (o adaptador atual é mock/log).
EMAIL_FROM=no-reply@tiescolar.test

# ---------- App ----------
APP_ENV=development
BACKEND_CORS_ORIGINS=http://localhost:3000
